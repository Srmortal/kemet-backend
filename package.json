{
  "name": "kemet-backend",
  "version": "1.0.0",
  "description": "Node.js backend API with TypeScript",
  "main": "dist/server.js",
  "imports": {
    "#app/*": {
      "source": "./src/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec \"node --conditions=source --loader ts-node/esm\" src/server.ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage --passWithNoTests=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests=false --coverageThreshold='{\"global\": {\"branches\": 90, \"functions\": 90, \"lines\": 90, \"statements\": 90}}'",
    "openapi:validate": "node scripts/ci/validate-openapi.js",
    "routes:check": "node --conditions=source --loader ts-node/esm scripts/ci/validate-routes-against-openapi.ts",
    "services:test-coverage": "node scripts/ci/check-service-tests.js",
    "ci": "npm run check && npm run typecheck && npm run openapi:validate && npm run routes:check && npm run services:test-coverage && npm run test:coverage",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:flush": "pm2 flush",
    "generate:contracts": "tsx scripts/generate-contracts.ts",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@paypal/paypal-server-sdk": "^1.0.3",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/pdf-parse": "^1.1.5",
    "ajv-formats": "^3.0.1",
    "awilix": "^13.0.0",
    "awilix-express": "^11.0.1",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-openapi-validator": "^5.6.2",
    "glob": "^13.0.0",
    "morgan": "^1.10.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.12",
    "openapi-backend": "^5.16.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "pm2": "^5.4.3",
    "prisma": "^6.19.2",
    "redis": "^5.10.0",
    "stripe": "^20.2.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@faker-js/faker": "^10.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.25",
    "@types/express-validator": "^2.20.33",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.29",
    "@types/nodemailer": "^7.0.5",
    "@types/paypal__checkout-server-sdk": "^1.0.8",
    "@types/pg": "^8.16.0",
    "@types/stripe": "^8.0.416",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "json-schema-ref-parser": "^9.0.9",
    "nodemon": "^3.1.11",
    "openapi-typescript": "^7.13.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "rc",
    "ultracite": "^7.2.4"
  },
  "type": "module"
}
