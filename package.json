{
  "name": "kemet-backend",
  "version": "1.0.0",
  "description": "Node.js backend API with TypeScript",
  "main": "dist/src/server.js",
  "scripts": {
    "start": "node dist/src/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc && tsc-alias",
    "clean": "rm -rf dist",
    "lint": "eslint --max-warnings=0 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage --passWithNoTests=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests=false --coverageThreshold='{\"global\": {\"branches\": 90, \"functions\": 90, \"lines\": 90, \"statements\": 90}}'",
    "openapi:validate": "node scripts/ci/validate-openapi.js",
    "routes:check": "ts-node scripts/ci/validate-routes-against-openapi.ts",
    "arch:enforce": "node scripts/ci/enforce-architecture.js",
    "services:test-coverage": "node scripts/ci/check-service-tests.js",
    "ci": "npm run lint && npm run typecheck && npm run openapi:validate && npm run routes:check && npm run arch:enforce && npm run services:test-coverage && npm run test:coverage",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:flush": "pm2 flush",
    "generate:api-types": "openapi-typescript contracts/openapi.yaml --output src/types/api.ts"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@paypal/paypal-server-sdk": "^1.0.3",
    "@types/pdf-parse": "^1.1.5",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-openapi-validator": "^5.6.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.0",
    "glob": "^13.0.0",
    "helmet": "^7.2.0",
    "joi": "^17.13.3",
    "module-alias": "^2.2.3",
    "morgan": "^1.10.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.12",
    "pdf-parse": "^2.4.5",
    "pm2": "^5.4.3",
    "redis": "^5.10.0",
    "stripe": "^20.2.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-validator": "^2.20.33",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.29",
    "@types/nodemailer": "^7.0.5",
    "@types/paypal__checkout-server-sdk": "^1.0.8",
    "@types/stripe": "^8.0.416",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "2.1.0",
    "jest": "^29.7.0",
    "json-schema-ref-parser": "^9.0.9",
    "nodemon": "^3.1.11",
    "openapi-typescript": "^7.10.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "_moduleAliases": {
    "@controllers": "dist/src/controllers",
    "@routes": "dist/src/routes",
    "@models": "dist/src/models",
    "@middleware": "dist/src/middleware",
    "@utils": "dist/src/utils",
    "@config": "dist/src/config",
    "@services": "dist/src/services",
    "@validators": "dist/src/validators",
    "@dto": "dist/src/dto",
    "@repositories": "dist/src/repositories",
    "@infrastructure": "dist/src/infrastructure"
  }
}
