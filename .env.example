# Environment Configuration
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=5000

# CORS
CORS_ORIGIN=*

# JWT Secret (for custom token signing)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-key-here

# Database (optional - for future Firestore integration)
# DATABASE_URL=

# PostgreSQL Database
# Format: postgresql://username:password@host:port/database_name
# POSTGRES_ANALYTICS_URL=postgresql://user:password@localhost:5432/kemet_db
# PG_MAX_CONNECTIONS=20
# PG_IDLE_TIMEOUT=30000
# PG_CONNECTION_TIMEOUT=2000

# Redis (optional - for caching)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Email Service (optional - for sending booking confirmations)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SEND_FROM_EMAIL=noreply@kemet.app

# Logging
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-password

# AWS (example - uncomment if using AWS services)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name