# Environment
NODE_ENV=development

# Server
PORT=3000

# CORS
CORS_ORIGIN=*

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Firebase Admin (Service Account)
# Provide either JSON path or individual fields below.
# If using JSON path (example):
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or set individual credentials (escape newlines in PRIVATE KEY):
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""
# Tazkarti integration (configure base and optional paths)
TAZKARTI_API_BASE=
TAZKARTI_EVENTS_PATH=/events
# For discovered path:
# TAZKARTI_EVENTS_PATH=/data/events-list-json.json
TAZKARTI_MATCHES_PATH=/matches
TAZKARTI_TIMEOUT=20000

# Shouf integration (travel tours and activities)
SHOUF_API_BASE=https://www.shouf.io
SHOUF_COLLECTIONS_PRODUCTS_PATH=/collections/{collection}/products.json
SHOUF_PRODUCTS_PATH=/products/{slug}.json
SHOUF_TIMEOUT=20000




# Database (example - uncomment and configure as needed)
# DATABASE_URL=mongodb://localhost:27017/kemet
# DATABASE_URL=postgresql://user:password@localhost:5432/kemet

# Redis (example - uncomment if using Redis)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Email (example - uncomment if using email service)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-password

# AWS (example - uncomment if using AWS services)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name

# Tazkarti integration
TAZKARTI_API_BASE=
TAZKARTI_EVENTS_PATH=/events
TAZKARTI_MATCHES_PATH=/matches
TAZKARTI_EVENT_CATEGORIES_PATH=/data/eventcategory-list.json
TAZKARTI_TIMEOUT=20000
TAZKARTI_IMAGE_BASE=https://www.tazkarti.com/assets/images/events/
