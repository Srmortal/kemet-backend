{
  "compilerOptions": {
    /* ================================
       TARGET & MODULE
    ================================= */
    "target": "ES2023",
    "module": "NodeNext",
    "lib": ["ES2023"],
    "moduleResolution": "nodenext",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",

    /* ================================
       STRICTNESS (Enterprise-Level)
    ================================= */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,

    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Enable when ready */
    "exactOptionalPropertyTypes": true,

    /* ================================
       OUTPUT
    ================================= */
    "outDir": "./dist",
    "rootDir": "./src",
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": true,

    /* ================================
       INTEROP
    ================================= */
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* ================================
       TYPES
    ================================= */
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "./src/infrastructure/@types"],

    /* ================================
       TS 6 SAFETY & PREDICTABILITY
    ================================= */
    "noUncheckedSideEffectImports": true,

    /* ================================
       PATH ALIASES (Feature-First)
    ================================= */
    "paths": {
      "#app/*": ["./src/*"]
    },

    /* ================================
       DECORATORS (if needed)
    ================================= */
    "experimentalDecorators": true
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "scripts", "prisma.config.ts", "tests"],

  "ts-node": {
    "files": true,
    "compilerOptions": {
      "module": "nodenext"
    }
  }
}
