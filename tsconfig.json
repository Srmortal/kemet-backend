{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node", "jest"],
    "typeRoots": [
      "./node_modules/@types",
      "./src/@types"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    // === Strict Type Checking ===
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    // === Additional Strictness ===
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    // "exactOptionalPropertyTypes": true,  // TODO: Enable after refactoring in-memory user store to Firestore
    // "noPropertyAccessFromIndexSignature": true,  // TODO: Enable after wrapping process.env in a typed config object
    // === Module Resolution ===
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    // === Source Maps & Declarations ===
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": true,
    // === Path Aliases ===
    "baseUrl": "./src",
    "paths": {
      "@controllers/*": ["controllers/*"],
      "@routes/*": ["routes/*"],
      "@models/*": ["models/*"],
      "@middleware/*": ["middleware/*"],
      "@utils/*": ["utils/*"],
      "@config/*": ["config/*"],
      "@services/*": ["services/*"],
      "@validators/*": ["validators/*"],
      "@dto/*": ["dto/*"],
      "@infrastructure/*": ["infrastructure/*"],
      "@repositories/*": ["repositories/*"]
    },
    "experimentalDecorators": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "scripts/**/*", "tests/**/*"],
  "ts-node": {
    "files": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}